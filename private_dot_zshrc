# Keep user-local and package-manager bins early in PATH so the same .zshrc
# works with Homebrew on macOS and ~/.local/bin installers on Linux.
typeset -U path PATH
[ -d "$HOME/.local/bin" ] && path=("$HOME/.local/bin" $path)
[ -d /opt/homebrew/bin ] && path=(/opt/homebrew/bin /opt/homebrew/sbin $path)
[ -d /usr/local/bin ] && path=(/usr/local/bin /usr/local/sbin $path)

command -v mise >/dev/null 2>&1 && eval "$(mise activate zsh)"
[ -f "$HOME/.config/zsh/shell.zsh" ] && source "$HOME/.config/zsh/shell.zsh"
