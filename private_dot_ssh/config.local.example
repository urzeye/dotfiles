# Copy this file to ~/.ssh/config.local and replace the example values.
#
# cp ~/.ssh/config.local.example ~/.ssh/config.local

Host my-server
  HostName 1.2.3.4
  User root
  Port 22
  IdentityFile ~/.ssh/id_ed25519

# Host bastion
