[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
	syntax-theme = Monokai Extended

[merge]
	conflictStyle = zdiff3

[init]
	defaultBranch = main

[fetch]
	prune = true

[rerere]
	enabled = true

